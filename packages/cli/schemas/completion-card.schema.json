{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "completion-card",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "tier",
    "owner",
    "accountable",
    "claim",
    "verification",
    "admission",
    "acceptance_status",
    "handoff"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "tier": {
      "enum": ["light", "standard", "deep"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "accountable": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "object",
      "required": ["fix_status", "summary", "evidence"],
      "properties": {
        "fix_status": {
          "enum": ["fixed", "not_fixed", "partial"]
        },
        "summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "state": {
      "type": "object",
      "properties": {
        "read_set": {
          "type": "array",
          "items": { "type": "string" }
        },
        "write_set": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflict_policy": {
          "type": "object",
          "properties": {
            "if_files_changed_after_claim": { "type": "string" },
            "if_tests_changed_after_claim": { "type": "string" }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "files_changed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "command_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "exit_code": {
                "type": "integer"
              },
              "runner": {
                "type": "string",
                "minLength": 1
              },
              "started_at": {
                "type": "string",
                "format": "date-time"
              },
              "ended_at": {
                "type": "string",
                "format": "date-time"
              },
              "stdout_hash": {
                "type": "string",
                "minLength": 1
              },
              "stderr_hash": {
                "type": "string",
                "minLength": 1
              },
              "artifact_path": {
                "type": "string",
                "minLength": 1
              },
              "artifact_hash": {
                "type": "string",
                "minLength": 1
              },
              "ci_run_url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "manual_rationale": {
          "type": "string"
        },
        "verification_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "status"],
            "properties": {
              "kind": {
                "enum": [
                  "typecheck",
                  "unit_test",
                  "integration_test",
                  "e2e_test",
                  "lint",
                  "build",
                  "static_analysis",
                  "security_scan",
                  "fuzz",
                  "performance_profile",
                  "manual_review",
                  "model_critique",
                  "custom"
                ]
              },
              "command": { "type": "string" },
              "status": {
                "enum": [
                  "passed",
                  "failed",
                  "blocked",
                  "skipped",
                  "timeout",
                  "error"
                ]
              },
              "verifies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "does_not_verify": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "enum": ["low", "medium", "high"]
              },
              "exit_code": {
                "type": "integer"
              },
              "runner": {
                "type": "string",
                "minLength": 1
              },
              "started_at": {
                "type": "string",
                "format": "date-time"
              },
              "ended_at": {
                "type": "string",
                "format": "date-time"
              },
              "stdout_hash": {
                "type": "string",
                "minLength": 1
              },
              "stderr_hash": {
                "type": "string",
                "minLength": 1
              },
              "artifact_path": {
                "type": "string",
                "minLength": 1
              },
              "artifact_hash": {
                "type": "string",
                "minLength": 1
              },
              "ci_run_url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "untested_regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remaining_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rollback_policy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_controls": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "pgv_advice": {
      "type": ["object", "null"],
      "description": "Optional PGV advice. Advisory-only; never grants admission authority."
    },
    "governance": {
      "type": "object",
      "properties": {
        "risk_class": {
          "enum": ["low", "medium", "high"]
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "approval_required_for": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approval_status": {
          "enum": ["not_required", "pending", "approved", "rejected"]
        },
        "approver": {
          "type": "string"
        },
        "approval_artifact": {
          "type": "object",
          "required": ["path", "sha256"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    },
    "intake": {
      "type": "object",
      "required": ["classification", "mapped_tier", "rationale"],
      "properties": {
        "classification": {
          "enum": ["tiny", "normal", "high_risk"]
        },
        "mapped_tier": {
          "enum": ["light", "standard", "deep"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "negative_signals_considered": {
          "type": "array",
          "items": { "type": "string" }
        },
        "auto_escalated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["status", "checks"],
      "properties": {
        "status": {
          "enum": ["passed", "failed", "skipped", "blocked", "timeout", "error"]
        },
        "checks": {
          "type": "array"
        }
      }
    },
    "admission": {
      "type": "object",
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "enum": [
            "success",
            "failed",
            "blocked",
            "skipped",
            "timeout",
            "error"
          ]
        }
      }
    },
    "acceptance_status": {
      "enum": ["accepted", "withheld"]
    },
    "context_acknowledged": {
      "type": "boolean",
      "description": "Advisory-only flag indicating the worker acknowledged context constraints. Missing or false does not block admission."
    },
    "context_alignment": {
      "type": "object",
      "description": "Optional context alignment evidence. References context-alignment.schema.json. Required for standard/deep per context-floor policy but optional at schema level for forward compatibility.",
      "$ref": "context-alignment.schema.json"
    },
    "product_intent": {
      "type": "object",
      "description": "Optional product intent status. Advisory-only; admission acceptance is not product correctness. When present, the engine emits advisory notes for missing or 'unknown' status on standard/deep tiers. Aligned/unreviewed/disputed/not_applicable do not block admission.",
      "properties": {
        "status": {
          "enum": [
            "aligned",
            "unreviewed",
            "disputed",
            "unknown",
            "not_applicable"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "test_adequacy": {
      "type": "object",
      "description": "Optional test adequacy declaration. Advisory-only; admission acceptance is not test adequacy. On standard/deep the engine emits advisory notes for a missing object or for missing/empty impacted_behaviors, tests_selected, why_sufficient. On deep, known_gaps must be present (an explicit [] is accepted and produces no note). Light tier remains quiet. Never blocks admission.",
      "properties": {
        "impacted_behaviors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_selected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "why_sufficient": {
          "type": "string"
        },
        "known_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "approval_receipt": {
      "type": "object",
      "description": "Optional approval receipt for high-risk command evidence. Required for standard/deep when evidence contains high-risk or unknown commands (standard: high/unknown; deep: medium/high/unknown).",
      "required": [
        "decision",
        "approver",
        "classified_commands",
        "aggregate_risk"
      ],
      "properties": {
        "decision": {
          "enum": ["approved", "rejected"]
        },
        "approver": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "classified_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["command", "risk"],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "risk": {
                "enum": ["low", "medium", "high"]
              }
            },
            "additionalProperties": false
          }
        },
        "aggregate_risk": {
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": false
    },
    "stale_ground": {
      "type": "boolean",
      "description": "Indicates the task context may be stale. When true, admission is blocked unless the stale ground is resolved. CLI flag --stale-ground overrides this card field."
    },
    "handoff": {
      "type": "object",
      "required": ["next_action", "owner"],
      "properties": {
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "done_checklist": {
      "type": "object",
      "properties": {
        "source_of_truth_read": {
          "type": "boolean"
        },
        "scope_explained": {
          "type": "boolean"
        },
        "read_write_sets_declared": {
          "type": "boolean"
        },
        "evidence_attached": {
          "type": "boolean"
        },
        "coverage_gap_declared": {
          "type": "boolean"
        },
        "risk_and_rollback_declared": {
          "type": "boolean"
        },
        "prediction_declared": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "prediction": {
      "type": "object",
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "expected_effect": {
          "type": "string",
          "minLength": 1
        },
        "measurable_signal": {
          "type": "string",
          "minLength": 1
        },
        "falsification_method": {
          "type": "string",
          "minLength": 1
        },
        "horizon": {
          "enum": [
            "same_verify",
            "next_ci_run",
            "next_release",
            "manual_review",
            "production_7d",
            "production_30d"
          ]
        },
        "confidence": {
          "enum": ["low", "medium", "high"]
        },
        "verdict": {
          "type": "object",
          "properties": {
            "status": {
              "enum": ["pending", "confirmed", "falsified", "inconclusive"]
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "claim",
        "expected_effect",
        "falsification_method",
        "horizon"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "verification": {
            "properties": {
              "status": { "const": "passed" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "claim": {
            "properties": {
              "fix_status": { "const": "fixed" }
            }
          }
        }
      },
      "else": {}
    },
    {
      "if": {
        "properties": {
          "acceptance_status": { "const": "accepted" }
        }
      },
      "then": {
        "properties": {
          "admission": {
            "properties": {
              "outcome": { "const": "success" }
            }
          }
        }
      },
      "else": {}
    },
    {
      "if": {
        "properties": {
          "admission": {
            "properties": {
              "outcome": {
                "enum": ["blocked", "failed", "skipped", "timeout", "error"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "handoff": {
            "properties": {
              "next_action": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 }
            },
            "required": ["next_action", "owner"]
          }
        }
      },
      "else": {}
    },
    {
      "if": {
        "properties": {
          "admission": {
            "properties": {
              "outcome": { "const": "success" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "claim": {
            "properties": {
              "fix_status": { "const": "fixed" }
            }
          },
          "verification": {
            "properties": {
              "status": { "const": "passed" }
            }
          },
          "acceptance_status": { "const": "accepted" }
        }
      },
      "else": {}
    }
  ]
}
