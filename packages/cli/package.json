{
  "name": "x-harness",
  "version": "0.1.0",
  "description": "A lightweight verify-gated harness for AI-agent workflows.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrianNguyen29/x-harness.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/BrianNguyen29/x-harness/issues"
  },
  "homepage": "https://github.com/BrianNguyen29/x-harness#readme",
  "keywords": [
    "ai-agents",
    "verification",
    "workflow",
    "cli",
    "governance",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "x-harness": "./dist/index.js",
    "xh": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:typecheck": "tsc --noEmit --project tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run typecheck && npm run build && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
