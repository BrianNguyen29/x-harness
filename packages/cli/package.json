{
  "name": "x-harness",
  "version": "0.99.0-rc1",
  "description": "A lightweight verify-gated harness for AI-agent workflows.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrianNguyen29/x-harness.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/BrianNguyen29/x-harness/issues"
  },
  "homepage": "https://github.com/BrianNguyen29/x-harness#readme",
  "keywords": [
    "ai-agents",
    "verification",
    "workflow",
    "cli",
    "governance"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "go-binaries",
    "schemas",
    "policies",
    "templates",
    "adapters",
    "examples",
    "skills",
    "docs",
    "components",
    "tools",
    "AGENTS.md",
    "X_HARNESS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    "packaging"
  ],
  "bin": {
    "x-harness": "./bin/x-harness.js",
    "xh": "./bin/x-harness.js"
  },
  "scripts": {
    "build": "tsc && node scripts/sync-package-assets.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:fast": "npm run test:smoke",
    "test:smoke": "vitest run admission.test.ts verify.test.ts doctor.test.ts examples.test.ts mutation-guard.test.ts ci-workflow.test.ts",
    "test:integration": "vitest run episode.test.ts frozen.test.ts federation.test.ts evidence.test.ts attribution.test.ts prediction.test.ts permissions.test.ts components.test.ts",
    "test:release": "npm run test && npm run pack:dry-run && node dist/index.js examples verify && node dist/index.js benchmark --filter adversarial --gate --json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:typecheck": "tsc --noEmit --project tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepack": "node scripts/sync-package-assets.mjs",
    "prepublishOnly": "node scripts/sync-package-assets.mjs",
    "ci": "npm run typecheck && npm run build && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "eslint": "^10.4.0",
    "fs-extra": "^11.3.5",
    "prettier": "^3.5.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  }
}
