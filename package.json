{
  "name": "x-harness-repo",
  "version": "0.99.0-rc7",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrianNguyen29/x-harness.git"
  },
  "bugs": {
    "url": "https://github.com/BrianNguyen29/x-harness/issues"
  },
  "homepage": "https://github.com/BrianNguyen29/x-harness#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/cli run build",
    "dev": "npm -w packages/cli run dev",
    "test": "npm -w packages/cli run test",
    "test:fast": "npm -w packages/cli run test:fast",
    "test:dot": "npm -w packages/cli run test:dot",
    "test:smoke": "npm -w packages/cli run test:smoke",
    "test:integration": "npm -w packages/cli run test:integration",
    "test:release": "npm -w packages/cli run test:release",
    "test:watch": "npm -w packages/cli run test:watch",
    "test:coverage": "npm -w packages/cli run test:coverage",
    "typecheck": "npm -w packages/cli run typecheck",
    "test:typecheck": "npm -w packages/cli run test:typecheck",
    "lint": "npm -w packages/cli run lint",
    "lint:fix": "npm -w packages/cli run lint:fix",
    "format": "npm -w packages/cli run format",
    "format:check": "npm -w packages/cli run format:check",
    "pack:dry-run": "npm -w packages/cli run pack:dry-run",
    "cli-metadata:write": "node scripts/generate-cli-docs.mjs --write",
    "cli-metadata:check": "node scripts/generate-cli-docs.mjs --check",
    "parity:capture-ts": "node scripts/capture-ts-baseline.mjs",
    "parity:check-ts": "node scripts/check-ts-baseline.mjs",
    "parity:check-go": "node scripts/check-go-parity.mjs",
    "ci": "npm -w packages/cli run ci",
    "release:local": "npm run build && npm run typecheck && npm run lint && npm run format:check && npm run test:release",
    "verify": "npm run build && npm run typecheck && npm run test",
    "verify:fast": "npm run build && npm run typecheck && npm run test:fast",
    "verify:drift": "bash tests/scripts/verify-adapters.sh && bash tests/scripts/verify-cli-docs.sh"
  }
}
