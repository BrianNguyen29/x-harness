{
  "name": "x-harness-repo",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrianNguyen29/x-harness.git"
  },
  "bugs": {
    "url": "https://github.com/BrianNguyen29/x-harness/issues"
  },
  "homepage": "https://github.com/BrianNguyen29/x-harness#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/cli run build",
    "dev": "npm -w packages/cli run dev",
    "test": "npm -w packages/cli run test",
    "test:watch": "npm -w packages/cli run test:watch",
    "test:coverage": "npm -w packages/cli run test:coverage",
    "typecheck": "npm -w packages/cli run typecheck",
    "test:typecheck": "npm -w packages/cli run test:typecheck",
    "lint": "npm -w packages/cli run lint",
    "lint:fix": "npm -w packages/cli run lint:fix",
    "format": "npm -w packages/cli run format",
    "format:check": "npm -w packages/cli run format:check",
    "ci": "npm -w packages/cli run ci",
    "verify": "npm run build && npm run typecheck && npm run test"
  }
}
