{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "XHarnessVerifyEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "task_id",
    "tier",
    "verifier",
    "verifier_mode",
    "outcome",
    "acceptance_status",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "const": "verify_completed"
    },
    "task_id": {
      "type": "string"
    },
    "story_id": {
      "type": "string"
    },
    "tier": {
      "enum": ["light", "standard", "deep"]
    },
    "claim_id": {
      "type": "string"
    },
    "evidence_id": {
      "type": "string"
    },
    "completion_card_id": {
      "type": "string"
    },
    "verifier": {
      "type": "string"
    },
    "verifier_mode": {
      "const": "read_only"
    },
    "outcome": {
      "enum": ["success", "failed", "blocked", "skipped", "timeout", "error"]
    },
    "acceptance_status": {
      "enum": ["accepted", "withheld"]
    },
    "blocking_predicate": {
      "type": ["string", "null"]
    },
    "blocked_reason_class": {
      "type": ["string", "null"]
    },
    "next_owner": {
      "type": ["string", "null"]
    },
    "next_action": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string"
    }
  }
}
