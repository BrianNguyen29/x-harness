{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "approval-receipt",
  "type": "object",
  "required": ["decision", "approver", "classified_commands", "aggregate_risk"],
  "properties": {
    "decision": {
      "enum": ["approved", "rejected"]
    },
    "approver": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "classified_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "risk"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": false
      }
    },
    "aggregate_risk": {
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": false
}
