{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "completion-card",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "tier",
    "owner",
    "accountable",
    "claim",
    "verification",
    "admission",
    "acceptance_status",
    "handoff"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "tier": {
      "enum": ["light", "standard", "deep"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "accountable": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "object",
      "required": ["fix_status", "summary", "evidence"],
      "properties": {
        "fix_status": {
          "enum": ["fixed", "not_fixed", "partial"]
        },
        "summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array"
        }
      }
    },
    "state": {
      "type": "object",
      "properties": {
        "read_set": {
          "type": "array",
          "items": { "type": "string" }
        },
        "write_set": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflict_policy": {
          "type": "object",
          "properties": {
            "if_files_changed_after_claim": { "type": "string" },
            "if_tests_changed_after_claim": { "type": "string" }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "files_changed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "command_evidence": {
          "type": "array"
        },
        "manual_rationale": {
          "type": "string"
        },
        "verification_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "status"],
            "properties": {
              "kind": {
                "enum": [
                  "typecheck",
                  "unit_test",
                  "integration_test",
                  "e2e_test",
                  "lint",
                  "build",
                  "static_analysis",
                  "security_scan",
                  "fuzz",
                  "performance_profile",
                  "manual_review",
                  "model_critique",
                  "custom"
                ]
              },
              "command": { "type": "string" },
              "status": {
                "enum": [
                  "passed",
                  "failed",
                  "blocked",
                  "skipped",
                  "timeout",
                  "error"
                ]
              },
              "verifies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "does_not_verify": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "enum": ["low", "medium", "high"]
              },
              "exit_code": {
                "type": "integer"
              },
              "started_at": {
                "type": "string",
                "format": "date-time"
              },
              "ended_at": {
                "type": "string",
                "format": "date-time"
              },
              "stdout_hash": {
                "type": "string",
                "minLength": 1
              },
              "stderr_hash": {
                "type": "string",
                "minLength": 1
              },
              "artifact_path": {
                "type": "string",
                "minLength": 1
              },
              "artifact_hash": {
                "type": "string",
                "minLength": 1
              },
              "ci_run_url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "untested_regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remaining_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rollback_policy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_controls": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "risk_class": {
          "enum": ["low", "medium", "high"]
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "approval_required_for": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approval_status": {
          "enum": ["not_required", "pending", "approved", "rejected"]
        },
        "approver": {
          "type": "string"
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "checks"],
      "properties": {
        "status": {
          "enum": ["passed", "failed", "skipped", "blocked", "timeout", "error"]
        },
        "checks": {
          "type": "array"
        }
      }
    },
    "admission": {
      "type": "object",
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "enum": ["success", "failed", "blocked", "skipped", "timeout", "error"]
        }
      }
    },
    "acceptance_status": {
      "enum": ["accepted", "withheld"]
    },
    "context_acknowledged": {
      "type": "boolean",
      "description": "Advisory-only flag indicating the worker acknowledged context constraints. Missing or false does not block admission."
    },
    "stale_ground": {
      "type": "boolean",
      "description": "Indicates the task context may be stale. When true, admission is blocked unless the stale ground is resolved. CLI flag --stale-ground overrides this card field."
    },
    "handoff": {
      "type": "object",
      "required": ["next_action", "owner"],
      "properties": {
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "verification": {
            "properties": {
              "status": { "const": "passed" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "claim": {
            "properties": {
              "fix_status": { "const": "fixed" }
            }
          }
        }
      },
      "else": {}
    },
    {
      "if": {
        "properties": {
          "acceptance_status": { "const": "accepted" }
        }
      },
      "then": {
        "properties": {
          "admission": {
            "properties": {
              "outcome": { "const": "success" }
            }
          }
        }
      },
      "else": {}
    },
    {
      "if": {
        "properties": {
          "admission": {
            "properties": {
              "outcome": {
                "enum": ["blocked", "failed", "skipped", "timeout", "error"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "handoff": {
            "properties": {
              "next_action": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 }
            },
            "required": ["next_action", "owner"]
          }
        }
      },
      "else": {}
    }
  ]
}
