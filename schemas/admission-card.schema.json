{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "admission-card",
  "type": "object",
  "required": ["schema_version", "generated_at", "x_harness_card"],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "x_harness_card": {
      "type": "object",
      "required": ["source_refs", "status"],
      "properties": {
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "exists"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "exists": {
                "type": "boolean"
              }
            }
          }
        },
        "status": {
          "type": "object",
          "required": ["ok"],
          "properties": {
            "ok": {
              "type": "boolean"
            },
            "note": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
